# Maintainer: dc138 <antonio@adaro.eu>
pkgname=mxctl-git
pkgver=0.1.0.r10.gee0c32f
pkgrel=1
pkgdesc="CLI for managing MXroute email accounts, forwarders, and catch-all policies"
arch=('any')
url="https://github.com/dc138/mxctl"
license=('MIT')
depends=('python' 'python-typer' 'python-httpx' 'python-pydantic')
makedepends=('git' 'python-build' 'python-installer' 'python-wheel' 'python-hatchling')
checkdepends=('python-pytest' 'python-pytest-httpserver')
provides=('mxctl')
conflicts=('mxctl')
source=("$pkgname::git+https://github.com/dc138/mxctl.git")
sha256sums=('SKIP')

pkgver() {
  cd "$pkgname"
  git describe --long --tags --abbrev=7 | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd "$pkgname"
  python -m build --wheel --no-isolation
}

check() {
  cd "$pkgname"
  local site_packages
  site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
  rm -rf testenv
  python -m installer --destdir=testenv dist/*.whl
  PYTHONPATH="$PWD/testenv/$site_packages" python -m pytest
}

package() {
  cd "$pkgname"
  python -m installer --destdir="$pkgdir" dist/*.whl
  local site_packages
  site_packages=$(python -c "import site; print(site.getsitepackages()[0])")
  PYTHONPATH="$pkgdir/$site_packages" _MXCTL_COMPLETE=source_bash "$pkgdir/usr/bin/mxctl" > mxctl.bash
  PYTHONPATH="$pkgdir/$site_packages" _MXCTL_COMPLETE=source_zsh "$pkgdir/usr/bin/mxctl" > _mxctl
  # compinit ignores the file unless #compdef is on the first line
  sed -i '/./,$!d' mxctl.bash _mxctl
  # invoke the function so the first tab press already completes
  echo '_mxctl_completion "$@"' >> _mxctl
  install -Dm644 mxctl.bash "$pkgdir/usr/share/bash-completion/completions/mxctl"
  install -Dm644 _mxctl "$pkgdir/usr/share/zsh/site-functions/_mxctl"
  install -Dm644 docs/mxctl.1 -t "$pkgdir/usr/share/man/man1"
  install -Dm644 LICENSE -t "$pkgdir/usr/share/licenses/$pkgname"
}
